#!/usr/bin/env bash
#
# pomeow — a cat that interrupts your terminal every Pomodoro break.
#

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do SOURCE="$(readlink "$SOURCE")"; done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
CATS_FILE="${SCRIPT_DIR}/cats.txt"

WORK_SECS="${POMEOW_WORK_SECS:-$((25 * 60))}"
BREAK_SECS="${POMEOW_BREAK_SECS:-$((4 * 60))}"

declare -a FRAMES
BREAK_LINES=0

# ---------------------------------------------------------------------------
# Load ASCII frames from cats.txt (frames separated by lines containing ---)
# ---------------------------------------------------------------------------
load_frames() {
    local frame=""
    while IFS= read -r line; do
        if [[ "$line" == "---" ]]; then
            [[ -n "$frame" ]] && FRAMES+=("$frame")
            frame=""
        elif [[ -z "$frame" ]]; then
            frame="$line"
        else
            frame+=$'\n'"$line"
        fi
    done < "$CATS_FILE"
    [[ -n "$frame" ]] && FRAMES+=("$frame")
}

# ---------------------------------------------------------------------------
# Display
# ---------------------------------------------------------------------------
fmt_time() {
    printf "%02d:%02d" $(( $1 / 60 )) $(( $1 % 60 ))
}

draw_work() {
    printf '\r\033[K  Work  %s' "$(fmt_time "$1")"
}

draw_break() {
    local frame="$1" elapsed=$2 lcount=0
    [[ $BREAK_LINES -gt 0 ]] && printf '\033[%dA' "$BREAK_LINES"
    while IFS= read -r line; do
        printf '\r\033[K%s\n' "$line"
        lcount=$(( lcount + 1 ))
    done <<< "$frame"
    printf '\r\033[K  +%s' "$(fmt_time "$elapsed")"
    BREAK_LINES=$lcount
}

erase_cat() {
    [[ $BREAK_LINES -gt 0 ]] && printf '\033[%dA\033[J' "$BREAK_LINES"
    BREAK_LINES=0
}

# ---------------------------------------------------------------------------
# Terminal cleanup
# ---------------------------------------------------------------------------
cleanup() {
    trap - INT TERM EXIT
    printf '\033[?25h\n'
    exit 0
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
main() {
    [[ -f "$CATS_FILE" ]] || { printf 'pomeow: cats.txt not found at %s\n' "$CATS_FILE" >&2; exit 1; }

    load_frames
    local nframes=${#FRAMES[@]}
    [[ $nframes -gt 0 ]] || { printf 'pomeow: no frames found in cats.txt\n' >&2; exit 1; }

    trap cleanup INT TERM EXIT
    printf '\033[?25l\n'

    local rem fidx next_change

    while true; do

        # --- Work phase ---
        rem=$WORK_SECS
        while [[ $rem -gt 0 ]]; do
            draw_work "$rem"
            sleep 1
            rem=$(( rem - 1 ))
        done
        printf '\n'

        # --- Break phase ---
        fidx=0
        rem=$BREAK_SECS
        next_change=$(( (RANDOM % 5) + 2 ))
        while [[ $rem -gt 0 ]]; do
            draw_break "${FRAMES[$fidx]}" $(( BREAK_SECS - rem ))
            sleep 1
            rem=$(( rem - 1 ))
            next_change=$(( next_change - 1 ))
            if [[ $next_change -le 0 ]]; then
                fidx=$(( (fidx + 1) % nframes ))
                next_change=$(( (RANDOM % 5) + 2 ))
            fi
        done
        erase_cat

    done
}

main
