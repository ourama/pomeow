#!/usr/bin/env bash
#
# pomeow — a cat that interrupts your terminal every Pomodoro break.
#

WORK_SECS="${POMEOW_WORK_SECS:-$((25 * 60))}"

BREAK_LINES=0

# ---------------------------------------------------------------------------
# ASCII cat frames (use $'...' to preserve backslashes on bash 3.2/macOS)
# ---------------------------------------------------------------------------
FRAMES=(
    $' /\\_/\\\n( o.o )\n > ^ <'
    $' /\\_/\\\n( -.- )\n > ^ <'
    $' /\\_/\\\n( -.- )\n(_____)'
    $' /\\_/\\\n( o.o )\n(_____)'
    $' /\\_/\\\n( ^.^ )\n(_____)'
    $' /\\_/\\\n( o.- )\n > ^ <'
    $' /\\_/\\\n( >.< )\n(_____)'
)

# ---------------------------------------------------------------------------
# Display
# ---------------------------------------------------------------------------
fmt_time() {
    printf "%02d:%02d" $(( $1 / 60 )) $(( $1 % 60 ))
}

draw_work() {
    printf '\r\033[K  Work  %s' "$(fmt_time "$1")"
}

draw_break() {
    local frame="$1" elapsed=$2 lcount=0
    [[ $BREAK_LINES -gt 0 ]] && printf '\033[%dA' "$BREAK_LINES"
    while IFS= read -r line; do
        printf '\r\033[K%s\n' "$line"
        lcount=$(( lcount + 1 ))
    done <<< "$frame"
    printf '\r\033[K\n'
    printf '\r\033[K  %s' "$(fmt_time "$elapsed")"
    BREAK_LINES=$(( lcount + 1 ))
}

erase_cat() {
    printf '\r\033[K  meow'
    sleep 2
    [[ $BREAK_LINES -gt 0 ]] && printf '\033[%dA\033[J' "$BREAK_LINES"
    BREAK_LINES=0
}

# ---------------------------------------------------------------------------
# Terminal cleanup
# ---------------------------------------------------------------------------
cleanup() {
    trap - INT TERM EXIT
    printf '\033[?25h\n'
    exit 0
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
main() {
    local nframes=${#FRAMES[@]}
    [[ $nframes -gt 0 ]] || { printf 'pomeow: no frames found\n' >&2; exit 1; }

    trap cleanup INT TERM EXIT
    printf '\033[?25l\n'

    local rem fidx next_change break_secs

    while true; do

        # --- Work phase ---
        rem=$WORK_SECS
        while [[ $rem -gt 0 ]]; do
            draw_work "$rem"
            sleep 1
            rem=$(( rem - 1 ))
        done
        printf '\n'

        # --- Break phase (3–5 min, random each visit) ---
        break_secs="${POMEOW_BREAK_SECS:-$(( (RANDOM % 3 + 3) * 60 ))}"
        fidx=0
        rem=$break_secs
        next_change=$(( (RANDOM % 5) + 2 ))
        while [[ $rem -gt 0 ]]; do
            draw_break "${FRAMES[$fidx]}" $(( break_secs - rem ))
            sleep 1
            rem=$(( rem - 1 ))
            next_change=$(( next_change - 1 ))
            if [[ $next_change -le 0 ]]; then
                fidx=$(( (fidx + 1) % nframes ))
                next_change=$(( (RANDOM % 5) + 2 ))
            fi
        done
        erase_cat

    done
}

main
