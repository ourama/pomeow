#!/usr/bin/env bash
#
# pomeow — a cat that interrupts your terminal every Pomodoro break.
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CATS_FILE="${SCRIPT_DIR}/cats.txt"

WORK_SECS="${POMEOW_WORK_SECS:-$((25 * 60))}"
BREAK_SECS="${POMEOW_BREAK_SECS:-$((4 * 60))}"

declare -a FRAMES
BREAK_LINES=0

# ---------------------------------------------------------------------------
# Load ASCII frames from cats.txt (frames separated by lines containing ---)
# ---------------------------------------------------------------------------
load_frames() {
    local frame="" has_content=0
    while IFS= read -r line; do
        if [[ "$line" == "---" ]]; then
            [[ $has_content -eq 1 ]] && FRAMES+=("$frame")
            frame=""; has_content=0
        else
            if [[ $has_content -eq 0 ]]; then
                frame="$line"; has_content=1
            else
                frame+=$'\n'"$line"
            fi
        fi
    done < "$CATS_FILE"
    [[ $has_content -eq 1 ]] && FRAMES+=("$frame")
}

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
fmt_time() {
    printf "%02d:%02d" $(( $1 / 60 )) $(( $1 % 60 ))
}

# Work phase: single-line timer, rewritten in place.
draw_work() {
    printf '\r\033[K  Work  %s' "$(fmt_time "$1")"
}

# Break phase: cat frame + timer, redrawn in place without clearing screen.
draw_break() {
    local frame="$1" remaining=$2 lcount=0
    [[ $BREAK_LINES -gt 0 ]] && printf '\033[%dA' "$BREAK_LINES"
    while IFS= read -r line; do
        printf '\r\033[K%s\n' "$line"
        lcount=$(( lcount + 1 ))
    done <<< "$frame"
    printf '\r\033[K  Break  %s' "$(fmt_time "$remaining")"
    BREAK_LINES=$lcount
}

# ---------------------------------------------------------------------------
# Terminal cleanup
# ---------------------------------------------------------------------------
cleanup() {
    trap - INT TERM EXIT
    printf '\033[?25h\n'
    exit 0
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
main() {
    [[ -f "$CATS_FILE" ]] || { printf 'pomeow: cats.txt not found at %s\n' "$CATS_FILE" >&2; exit 1; }

    load_frames
    local nframes=${#FRAMES[@]}
    [[ $nframes -gt 0 ]] || { printf 'pomeow: no frames found in cats.txt\n' >&2; exit 1; }

    trap cleanup INT TERM EXIT
    printf '\033[?25l\n'

    while true; do

        # --- Work phase ---
        local rem=$WORK_SECS
        while [[ $rem -gt 0 ]]; do
            draw_work "$rem"
            sleep 1
            rem=$(( rem - 1 ))
        done
        printf '\n'

        # --- Break phase ---
        BREAK_LINES=0
        local fidx=0
        rem=$BREAK_SECS
        local next_change=$(( (RANDOM % 5) + 2 ))
        while [[ $rem -gt 0 ]]; do
            draw_break "${FRAMES[$fidx]}" "$rem"
            sleep 1
            rem=$(( rem - 1 ))
            next_change=$(( next_change - 1 ))
            if [[ $next_change -le 0 ]]; then
                fidx=$(( (fidx + 1) % nframes ))
                next_change=$(( (RANDOM % 5) + 2 ))
            fi
        done
        printf '\n'

    done
}

main
